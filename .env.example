PORT=8080
ENV=development

# Option 1: full DSN
DATABASE_URL=postgres://postgres:postgres@localhost:5432/availability_scheduler?sslmode=disable

# Option 2: individual vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=availability_scheduler
DB_SSLMODE=disable
